{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigests",
    ":automergePr"
  ],
  "schedule": ["before 1am on sunday"],
  "separateMajorMinor": false,
  "minimumReleaseAge": "10 days",
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "enabled": false
    },
    {
      "matchManagers": ["pip_requirements"],
      "groupName": "python dependencies"
    },
    {
      "matchManagers": ["dockerfile"],
      "groupName": "container base images"
    },
    {
      "matchManagers": ["regex"],
      "groupName": "cli tools"
    },
    {
      "matchManagers": ["mise"],
      "groupName": "mise-managed cli tools",
      "description": "CLI tools pinned in roles/packages/files/mise.toml. Regenerate mise.lock (make mise-lock) after a bump."
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "matchManagers": ["npm"],
      "groupName": "npm dependencies"
    }
  ],
  "customDatasources": {
    "openshift-mirror": {
      "defaultRegistryUrlTemplate": "https://mirror.openshift.com/pub/openshift-v4/x86_64/clients/ocp/stable-4.21/release.txt",
      "format": "plain",
      "transformTemplates": [
        "{ \"releases\": [ { \"version\": $match($, /^Version:\\s+(\\S+)/).groups[0] } ] }"
      ]
    }
  },
  "customManagers": [
    {
      "description": "Update pinned versions in Ansible defaults",
      "customType": "regex",
      "managerFilePatterns": ["roles/**/*.yml"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: extractVersion=(?<extractVersion>\\S+))?\\n\\w+:\\s+\"?(?<currentValue>[^\"\\n]+)\"?"
      ],
      "versioningTemplate": "semver"
    },
    {
      "description": "Update pinned pip package versions in Ansible defaults",
      "customType": "regex",
      "managerFilePatterns": ["roles/**/*.yml"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s+-\\s+\"\\S+=+(?<currentValue>[^\"]+)\""
      ],
      "versioningTemplate": "pep440"
    }
  ]
}
